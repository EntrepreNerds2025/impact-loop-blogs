# Brand selection (set per Vercel deployment)
# BRAND=impact-loop

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=ngkvlovw
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=           # Create at sanity.io/manage -> API -> Tokens -> Add token (must allow create/update/delete)

# AI Auto Blog Endpoint Security
AI_AUTOBLOG_SECRET=         # Shared secret used by /api/ai/blog (send via x-ai-secret header)

# AI provider: openai (default) or anthropic
AI_PROVIDER=openai

# OpenAI models
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_RESEARCH_MODEL=      # Optional override; falls back to OPENAI_MODEL
OPENAI_WRITER_MODEL=        # Optional override; falls back to OPENAI_MODEL
OPENAI_AUDIT_MODEL=         # Optional override; falls back to OPENAI_MODEL
OPENAI_ENABLE_WEB_SEARCH=true

# Anthropic models (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
ANTHROPIC_RESEARCH_MODEL=   # Optional override
ANTHROPIC_WRITER_MODEL=     # Optional override
ANTHROPIC_AUDIT_MODEL=      # Optional override
ANTHROPIC_MODEL_FALLBACKS=claude-3-5-sonnet-latest,claude-3-5-haiku-latest

# Quality gates (publish is blocked when below threshold)
AI_AUTOBLOG_MIN_SEO_SCORE=85
AI_AUTOBLOG_MIN_TONE_SCORE=85

# Optional: used to return direct Studio edit links in API responses
SANITY_STUDIO_BASE_URL=http://localhost:3333
