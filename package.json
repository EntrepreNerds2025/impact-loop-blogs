{
  "name": "impact-loop-blogs",
  "version": "0.1.0",
  "private": true,
  "description": "Single Next.js monorepo powering blogs for Impact Loop, Rovonn Russell, Dream Streams, and IL Foundation. One codebase, four Vercel deployments, brand selected via BRAND env var.",
  "scripts": {
    "dev": "next dev",
    "dev:impact-loop": "BRAND=impact-loop next dev",
    "dev:rovonn-russell": "BRAND=rovonn-russell next dev",
    "dev:dream-streams": "BRAND=dream-streams next dev",
    "dev:il-foundation": "BRAND=il-foundation next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "sync:crm-catalog": "node scripts/sync-blog-catalog.mjs",
    "type-check": "tsc --noEmit",
    "studio:dev": "cd studio && npx sanity dev",
    "studio:build": "cd studio && npx sanity build",
    "studio:deploy": "cd studio && npx sanity deploy",
    "studio:login": "cd studio && npx sanity login",
    "studio:projects": "cd studio && npx sanity projects list",
    "studio:import": "cd studio && npx sanity dataset import ../sanity/import.ndjson production --replace"
  },
  "dependencies": {
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "clsx": "2.1.1",
    "feed": "4.2.2",
    "gray-matter": "4.0.3",
    "next": "14.2.33",
    "next-mdx-remote": "6.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "7.1.0",
    "rehype-pretty-code": "0.13.2",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.0",
    "shiki": "1.22.0"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.33",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
